#!/usr/bin/env bash

_abort(){
  echo "Usage: csvshell <csv_file> <csv_file_2> ..."
  exit 1
}

[ $# -eq 0 ] && _abort

db_file=$(mktemp "${TMPDIR}.csvshell.XXXXXX")

echo "Populating temporary database: $db_file"
csvsql --no-inference --db "sqlite:///$db_file" --insert "$@"

echo "Use .tables to list tables"

echo "Starting sqlite3 console..."
sqlite3 "$db_file"

echo "Removing temporary file: $db_file"
rm "$db_file"
